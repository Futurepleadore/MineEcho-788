# MineEcho BFF local-first defaults.
# Copy this file to .env and keep real tokens or production endpoints local.

# OpenClaw Gateway WebSocket URL used by the BFF.
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Optional local gateway token. Leave unset unless your local Gateway requires it.
# OPENCLAW_GATEWAY_TOKEN=replace-with-local-token

# BFF HTTP port. Default: 3085.
# BFF_PORT=3085

# Memory and performance guardrails.

# Daily interaction cap. Default: 300.
# MAX_DAILY_INTERACTIONS=300

# Long-term memory cache user cap. Default: 1000.
# MAX_MEMORY_CACHE_SIZE=1000

# Short-term memory cache item cap. Default: 10000.
# MAX_SHORTTERMMEMORYSTORE_SIZE=10000

# Batch write interval in milliseconds. Default: 30000.
# BATCH_WRITE_INTERVAL_MS=30000

# Disable batch writes. Default: false.
# ENABLE_BATCH_WRITE=false
